---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const basePath = '/claude-code-tips';
const allTips = await getCollection('tips');
const allTipsSorted = allTips.sort((a, b) => a.data.id - b.data.id);

// Serialize tips for client-side filtering
const tipsData = JSON.stringify(allTipsSorted.map(tip => ({
  id: tip.data.id,
  title: tip.data.title,
  description: tip.data.description,
  act: tip.data.act,
  difficulty: tip.data.difficulty,
  category: tip.data.category,
  tags: tip.data.tags,
  timestamp: tip.data.timestamp
})));

const difficulties = ['beginner', 'intermediate', 'advanced'];
const categories = ['setup', 'workflow', 'power-user', 'advanced'];
---

<Layout title="技巧列表 - Claude Code Tips">
  <div class="container">
    <div class="tips-layout">
      <aside class="sidebar">
        <h3>筛选</h3>

        <div class="filter-section">
          <h4>按 Act</h4>
          <ul class="filter-list">
            <li><button data-filter="act" data-value="" class="filter-link active">全部</button></li>
            <li><button data-filter="act" data-value="1" class="filter-link">Act 1: Getting Started</button></li>
            <li><button data-filter="act" data-value="2" class="filter-link">Act 2: Daily Workflow</button></li>
            <li><button data-filter="act" data-value="3" class="filter-link">Act 3: Power User</button></li>
            <li><button data-filter="act" data-value="4" class="filter-link">Act 4: Advanced</button></li>
          </ul>
        </div>

        <div class="filter-section">
          <h4>按难度</h4>
          <ul class="filter-list">
            <li><button data-filter="difficulty" data-value="" class="filter-link active">全部</button></li>
            {difficulties.map(d => (
              <li>
                <button data-filter="difficulty" data-value={d} class="filter-link">{d}</button>
              </li>
            ))}
          </ul>
        </div>

        <div class="filter-section">
          <h4>按分类</h4>
          <ul class="filter-list">
            <li><button data-filter="category" data-value="" class="filter-link active">全部</button></li>
            {categories.map(c => (
              <li>
                <button data-filter="category" data-value={c} class="filter-link">{c}</button>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <main class="main-content">
        <div class="header">
          <h1>技巧列表</h1>
          <p class="count">显示 <span id="tip-count">0</span> 个技巧</p>
          <div class="header-actions">
            <a href={`${basePath}/tips/all`} class="btn btn-outline btn-sm">一览模式</a>
          </div>
        </div>

        <div class="tips-grid" id="tips-grid">
          <!-- Tips will be rendered by JavaScript -->
        </div>

        <div class="empty hidden" id="empty-state">
          <p>没有找到匹配的技巧</p>
          <button id="clear-filters" class="btn btn-outline">清除筛选</button>
        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  .tips-layout {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: var(--spacing-2xl);
    padding-top: var(--spacing-xl);
  }

  .sidebar {
    position: sticky;
    top: var(--spacing-xl);
    align-self: start;
  }

  .sidebar h3 {
    margin-bottom: var(--spacing-lg);
  }

  .filter-section {
    margin-bottom: var(--spacing-lg);
  }

  .filter-section h4 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-sm);
  }

  .filter-list {
    list-style: none;
  }

  .filter-list li {
    margin-bottom: var(--spacing-xs);
  }

  .filter-list :global(.filter-link) {
    color: var(--color-text-light);
    text-decoration: none;
    display: block;
    width: 100%;
    text-align: left;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    transition: background var(--transition), color var(--transition);
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    font-family: inherit;
  }

  .filter-list :global(.filter-link:hover),
  .filter-list :global(.filter-link.active) {
    background: var(--color-border);
    color: var(--color-text);
  }

  .filter-list :global(.filter-link.active) {
    font-weight: 500;
  }

  .header {
    margin-bottom: var(--spacing-lg);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .header h1 {
    margin: 0;
  }

  .header-actions {
    display: flex;
    gap: var(--spacing-sm);
  }

  .btn-sm {
    padding: var(--spacing-xs) var(--spacing-md);
    font-size: 0.875rem;
  }

  .count {
    color: var(--color-text-light);
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  .tip-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }

  .tip-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-sm);
  }

  .tip-id {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .badges {
    display: flex;
    gap: var(--spacing-xs);
  }

  .tip-card h2 {
    font-size: 1.125rem;
    margin-bottom: var(--spacing-sm);
  }

  .tip-card p {
    flex: 1;
    color: var(--color-text-light);
    font-size: 0.9375rem;
  }

  .tip-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-border);
  }

  .timestamp {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .tags {
    display: flex;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  .empty {
    text-align: center;
    padding: var(--spacing-3xl);
  }

  .hidden {
    display: none;
  }

  @media (max-width: 768px) {
    .tips-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
    }
  }
</style>

<script is:inline define:vars={{ tipsData, basePath }}>
  const allTips = JSON.parse(tipsData);
  const basePathValue = basePath;
  let currentFilters = {
    act: '',
    difficulty: '',
    category: ''
  };

  const tipsGrid = document.getElementById('tips-grid');
  const tipCount = document.getElementById('tip-count');
  const emptyState = document.getElementById('empty-state');
  const clearBtn = document.getElementById('clear-filters');

  function renderTips(tips) {
    if (tips.length === 0) {
      tipsGrid.classList.add('hidden');
      emptyState.classList.remove('hidden');
      tipCount.textContent = '0';
      return;
    }

    tipsGrid.classList.remove('hidden');
    emptyState.classList.add('hidden');
    tipCount.textContent = tips.length;

    tipsGrid.innerHTML = tips.map(tip => `
      <a href="${basePathValue}/tips/${tip.id}" class="card tip-card">
        <div class="tip-header">
          <span class="tip-id">#${tip.id}</span>
          <div class="badges">
            <span class="badge badge-${tip.difficulty}">${tip.difficulty}</span>
            <span class="tag">Act ${tip.act}</span>
          </div>
        </div>
        <h2>${tip.title}</h2>
        <p>${tip.description}</p>
        <div class="tip-footer">
          <span class="timestamp">${tip.timestamp}</span>
          <div class="tags">
            ${tip.tags.slice(0, 3).map(tag => `<span class="tag">${tag}</span>`).join('')}
          </div>
        </div>
      </a>
    `).join('');
  }

  function filterTips() {
    let filtered = allTips;

    if (currentFilters.act) {
      filtered = filtered.filter(tip => tip.act === parseInt(currentFilters.act));
    }
    if (currentFilters.difficulty) {
      filtered = filtered.filter(tip => tip.difficulty === currentFilters.difficulty);
    }
    if (currentFilters.category) {
      filtered = filtered.filter(tip => tip.category === currentFilters.category);
    }

    renderTips(filtered);
  }

  function updateActiveStates() {
    document.querySelectorAll('.filter-link').forEach(btn => {
      const filterType = btn.dataset.filter;
      const value = btn.dataset.value;

      if (currentFilters[filterType] === value) {
        btn.classList.add('active');
      } else if (value === '' && !currentFilters[filterType]) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }

  // Filter button clicks
  document.querySelectorAll('.filter-link').forEach(btn => {
    btn.addEventListener('click', () => {
      const filterType = btn.dataset.filter;
      const value = btn.dataset.value;

      currentFilters[filterType] = value;
      updateActiveStates();
      filterTips();
    });
  });

  // Clear filters button
  clearBtn?.addEventListener('click', () => {
    currentFilters = { act: '', difficulty: '', category: '' };
    updateActiveStates();
    filterTips();
  });

  // Initial render
  renderTips(allTips);
</script>
