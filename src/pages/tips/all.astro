---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTips = await getCollection('tips');
const allTipsSorted = allTips.sort((a, b) => a.data.id - b.data.id);

// Pre-render all tips
const tipsWithContent = await Promise.all(
  allTipsSorted.map(async (tip) => {
    const { Content } = await tip.render();
    return {
      ...tip,
      Content
    };
  })
);

const difficulties = ['beginner', 'intermediate', 'advanced'];
const categories = ['setup', 'workflow', 'power-user', 'advanced'];

// Chinese titles for tips (key: tip id, value: Chinese title)
const zhTitles = {
  1: "从根目录运行",
  2: "立即运行 /init",
  3: "CLAUDE.md 的层级结构",
  4: "明确需求描述",
  5: "分而治之",
  6: "先检查再询问",
  7: "使用 /btw 保存上下文",
  8: "创建专用分支",
  9: "通过拉取请求集成",
  10: "整理你的问题",
  11: "使用指向而非描述",
  12: "避免模糊的指令",
  13: "一个任务一个请求",
  14: "验证理解",
  15: "打开正确的文件",
  16: "描述你看到的内容",
  17: "说明期望行为",
  18: "提供错误信息",
  19: "逐个文件修复",
  20: "重构前问为什么",
  21: "使用 /plan 进行规划",
  22: "先接受计划",
  23: "迭代规划",
  24: "规划模式输出",
  25: "高效的代码审查",
  26: "审查前询问",
  27: "分批审查",
  28: "使用建议",
  29: "自定义审查",
  30: "接受建议的时机",
  31: "何时问如何",
  32: "分步教学",
  33: "探索代码库",
  34: "技术决策",
  35: "代码解释",
  36: "模式识别",
  37: "使用 /context",
  38: "定期使用 /clear",
  39: "切换模型",
  40: "使用工作区",
  41: "快速文件访问",
  42: "内容感知编辑",
  43: "读取大文件",
  44: "批处理操作",
  45: "保存会话",
  46: "恢复会话",
  47: "使用 /resume",
  48: "会话搜索",
  49: "阻止危险命令",
  50: "探索插件生态"
};
---

<Layout title="所有技巧一览 - Claude Code Tips">
  <div class="container">
    <div class="header">
      <div class="header-top">
        <h1>所有技巧一览</h1>
        <button id="lang-toggle" class="lang-toggle" aria-label="切换语言">
          <span class="lang-current">EN</span>
          <span class="lang-separator">/</span>
          <span class="lang-other">中文</span>
        </button>
      </div>
      <p class="subtitle">完整的 50 个 Claude Code 使用技巧，适合演示和培训使用</p>
      <div class="actions">
        <a href="/tips" class="btn btn-outline">返回卡片视图</a>
      </div>
    </div>

    <div class="tips-list">
      {tipsWithContent.map((tip, index) => (
        <div class={`tip-item collapsed act-${tip.data.act} difficulty-${tip.data.difficulty}`} data-tip-id={tip.data.id}>
          <div class="tip-header" onclick={`toggleTip(${tip.data.id})`}>
            <div class="tip-meta">
              <span class="tip-number">#{tip.data.id}</span>
              <span class={`badge badge-${tip.data.difficulty}`}>{tip.data.difficulty}</span>
              <span class="act-badge">Act {tip.data.act}</span>
              <span class="category-badge">{tip.data.category}</span>
              <span class="timestamp">{tip.data.timestamp}</span>
            </div>
            <div class="tip-title-row">
              <h2 data-title-en={tip.data.title} data-title-zh={zhTitles[tip.data.id] || tip.data.title}>{tip.data.title}</h2>
              <button class="toggle-btn" aria-label="展开/收起" data-tip-id={tip.data.id}>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
              </button>
            </div>
            <p class="description">{tip.data.description}</p>
            <div class="tip-tags">
              {tip.data.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>

          <div class="tip-content">
            <div class="tip-body">
              <tip.Content />
            </div>
          </div>

          {tip.data.related && tip.data.related.length > 0 && (
            <div class="tip-related">
              <strong>相关技巧：</strong>
              {tip.data.related.map(relatedId => {
                const relatedTip = tipsWithContent.find(t => t.data.id === relatedId);
                return relatedTip ? (
                  <a href={`#tip-${relatedId}`} class="related-link">#{relatedId} {relatedTip.data.title}</a>
                ) : null;
              })}
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="footer-nav">
      <a href="/tips" class="btn">返回技巧列表</a>
      <a href="/demo" class="btn btn-outline">查看交互演示</a>
    </div>
  </div>
</Layout>

<style>
  .header {
    text-align: center;
    padding: var(--spacing-3xl) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-2xl);
  }

  .header h1 {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-primary);
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .header-top h1 {
    margin: 0;
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    background: var(--color-surface);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-sm) var(--spacing-md);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all var(--transition);
  }

  .lang-toggle:hover {
    background: var(--color-primary);
  }

  .lang-toggle:hover .lang-current,
  .lang-toggle:hover .lang-other {
    color: white;
  }

  .lang-current {
    color: var(--color-primary);
  }

  .lang-separator {
    color: var(--color-text-light);
  }

  .lang-other {
    color: var(--color-text-light);
  }

  .lang-toggle[data-lang="zh"] .lang-current {
    color: var(--color-text-light);
  }

  .lang-toggle[data-lang="zh"] .lang-other {
    color: var(--color-primary);
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-lg);
  }

  .actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
  }

  .tips-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xl);
  }

  .tip-item {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    scroll-margin-top: var(--spacing-2xl);
  }

  .tip-item.collapsed .tip-content {
    display: none;
  }

  .tip-item.collapsed .tip-related {
    display: none;
  }

  .tip-header {
    padding: var(--spacing-lg);
    background: linear-gradient(135deg, var(--color-bg) 0%, #f5f0ed 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .tip-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    margin-bottom: var(--spacing-md);
  }

  .tip-number {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(217, 119, 87, 0.1);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
  }

  .badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
  }

  .badge-beginner {
    background: #d4edda;
    color: #155724;
  }

  .badge-intermediate {
    background: #fff3cd;
    color: #856404;
  }

  .badge-advanced {
    background: #f8d7da;
    color: #721c24;
  }

  .act-badge {
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--color-primary);
    color: white;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
  }

  .category-badge {
    font-size: 0.75rem;
    background: #e7f3ff;
    color: #004085;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
  }

  .timestamp {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-left: auto;
  }

  .tip-header h2 {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .tip-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-md);
  }

  .tip-title-row h2 {
    margin: 0;
    flex: 1;
  }

  .toggle-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: var(--spacing-sm);
    border-radius: var(--radius-md);
    color: var(--color-primary);
    transition: all var(--transition);
    flex-shrink: 0;
  }

  .toggle-btn:hover {
    background: rgba(217, 119, 87, 0.1);
  }

  .toggle-btn svg {
    transition: transform var(--transition);
  }

  .tip-item.collapsed .toggle-btn svg {
    transform: rotate(-90deg);
  }

  .tip-item:not(.collapsed) .toggle-btn svg {
    transform: rotate(0deg);
  }

  .description {
    font-size: 1rem;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-md);
  }

  .tip-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .tip-tags .tag {
    font-size: 0.75rem;
    background: var(--color-border);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    color: var(--color-text-light);
  }

  .tip-content {
    padding: var(--spacing-xl);
  }

  .tip-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .tip-body :global(h2) {
    font-size: 1.25rem;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
    border-bottom: 2px solid var(--color-primary);
    padding-bottom: var(--spacing-xs);
  }

  .tip-body :global(h3) {
    font-size: 1.125rem;
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .tip-body :global(p) {
    margin-bottom: var(--spacing-md);
  }

  .tip-body :global(code) {
    background: #1E1E1E;
    color: #D97757;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }

  .tip-body :global(pre) {
    background: #1E1E1E;
    color: #E8E8E8;
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--spacing-md);
  }

  .tip-body :global(pre code) {
    background: transparent;
    color: #E8E8E8;
    padding: 0;
  }

  /* Highlight commands like /init in orange */
  .tip-body :global(code):global(.command),
  .tip-body :global(pre code):global(.command) {
    color: #FF9F7D;
    font-weight: 500;
  }

  .tip-body :global(ul),
  .tip-body :global(ol) {
    margin-bottom: var(--spacing-md);
    padding-left: var(--spacing-lg);
  }

  .tip-body :global(li) {
    margin-bottom: var(--spacing-xs);
  }

  .tip-body :global(a) {
    color: var(--color-primary);
    text-decoration: none;
  }

  .tip-body :global(a:hover) {
    text-decoration: underline;
  }

  .tip-related {
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    font-size: 0.875rem;
  }

  .tip-related strong {
    color: var(--color-text);
    margin-right: var(--spacing-sm);
  }

  .related-link {
    color: var(--color-primary);
    text-decoration: none;
    margin-right: var(--spacing-md);
  }

  .related-link:hover {
    text-decoration: underline;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
    padding: var(--spacing-3xl) 0;
    border-top: 1px solid var(--color-border);
    margin-top: var(--spacing-3xl);
  }

  @media (max-width: 768px) {
    .header h1 {
      font-size: 1.75rem;
    }

    .tip-header h2 {
      font-size: 1.25rem;
    }

    .tip-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .timestamp {
      margin-left: 0;
    }
  }
</style>

<script>
  // Language switching
  let currentLang = localStorage.getItem('tips-lang') || 'en';
  const langToggle = document.getElementById('lang-toggle');

  function updateLanguage() {
    const titles = document.querySelectorAll('[data-title-en]');
    titles.forEach(title => {
      const en = title.getAttribute('data-title-en');
      const zh = title.getAttribute('data-title-zh');
      title.textContent = currentLang === 'zh' ? zh : en;
    });

    // Update toggle button state
    langToggle?.setAttribute('data-lang', currentLang);
    const currentSpan = langToggle?.querySelector('.lang-current');
    const otherSpan = langToggle?.querySelector('.lang-other');
    if (currentLang === 'zh') {
      currentSpan.textContent = '中文';
      otherSpan.textContent = 'EN';
    } else {
      currentSpan.textContent = 'EN';
      otherSpan.textContent = '中文';
    }
  }

  langToggle?.addEventListener('click', () => {
    currentLang = currentLang === 'en' ? 'zh' : 'en';
    localStorage.setItem('tips-lang', currentLang);
    updateLanguage();
  });

  // Initialize language
  updateLanguage();

  // Add IDs to tip items for anchor navigation
  document.querySelectorAll('.tip-item').forEach((item) => {
    const id = item.querySelector('.tip-number')?.textContent;
    if (id) {
      item.id = `tip-${id.replace('#', '')}`;
    }
  });

  // Toggle tip expansion
  function toggleTip(tipId: string) {
    const tipItem = document.querySelector(`.tip-item[data-tip-id="${tipId}"]`);
    if (tipItem) {
      tipItem.classList.toggle('collapsed');
    }
  }

  // Make function available globally
  (window as any).toggleTip = toggleTip;

  // Handle toggle button clicks separately
  document.querySelectorAll('.toggle-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const tipId = btn.getAttribute('data-tip-id');
      if (tipId) toggleTip(tipId);
    });
  });

  // Handle direct anchor links by expanding the target tip
  if (window.location.hash) {
    const targetId = window.location.hash.replace('#tip-', '');
    const tipItem = document.querySelector(`.tip-item[data-tip-id="${targetId}"]`);
    if (tipItem) {
      tipItem.classList.remove('collapsed');
    }
  }
</script>
