---
import Layout from '../layouts/Layout.astro';
---

<Layout title="交互演示 - Claude Code Tips">
  <div class="container">
    <h1>交互演示</h1>
    <p class="subtitle">体验 Claude Code 的界面和交互</p>

    <div class="demo-container">
      <div class="terminal">
        <div class="terminal-header">
          <div class="dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="title">claude-code</div>
        </div>

        <div class="terminal-content" id="terminal-content">
          <!-- Demo messages will be inserted here -->
        </div>

        <div class="input-area">
          <span class="prompt">></span>
          <input type="text" id="demo-input" placeholder="输入命令或消息..." />
          <button id="send-btn">发送</button>
        </div>
      </div>

      <div class="presets-wrapper">
        <div class="presets-section">
          <h3>📋 基础命令</h3>
          <button class="preset-btn" data-cmd="/help">/help - 显示帮助</button>
          <button class="preset-btn" data-cmd="/init">/init - 初始化项目</button>
          <button class="preset-btn" data-cmd="/clear">/clear - 清空对话</button>
          <button class="preset-btn" data-cmd="/context">/context - Token 使用</button>
          <button class="preset-btn" data-cmd="/btw">/btw - 侧链对话</button>
        </div>

        <div class="presets-section">
          <h3>🔄 工作流命令</h3>
          <button class="preset-btn" data-cmd="/model">/model - 切换模型</button>
          <button class="preset-btn" data-cmd="/plan">/plan - 进入规划模式</button>
          <button class="preset-btn" data-cmd="/resume">/resume - 恢复会话</button>
          <button class="preset-btn" data-cmd="/mcp">/mcp - MCP 状态</button>
        </div>

        <div class="presets-section">
          <h3>💬 对话示例</h3>
          <button class="preset-btn" data-cmd="team mode, member 1 修复用户登录的 token 过期问题，member 2 分析 API 响应慢的原因">Team Mode 并行协作</button>
          <button class="preset-btn" data-cmd="审查这个 PR 的安全性，检查是否有 SQL 注入风险">安全审查示例</button>
          <button class="preset-btn" data-cmd="重构认证模块，使用 JWT 替代 session，需要保持向后兼容">复杂重构任务</button>
          <button class="preset-btn" data-cmd="写单元测试覆盖用户注册流程，包括正常和异常情况">测试编写示例</button>
        </div>
      </div>
    </div>

    <div class="commands-reference">
      <h2>Slash Commands 参考</h2>
      <div class="commands-grid">
        <div class="command-card">
          <code>/init</code>
          <p>初始化项目配置，创建 CLAUDE.md</p>
        </div>
        <div class="command-card">
          <code>/help</code>
          <p>显示所有可用命令</p>
        </div>
        <div class="command-card">
          <code>/clear</code>
          <p>清空对话上下文</p>
        </div>
        <div class="command-card">
          <code>/context</code>
          <p>查看 token 使用情况</p>
        </div>
        <div class="command-card">
          <code>/model</code>
          <p>切换 AI 模型</p>
        </div>
        <div class="command-card">
          <code>/plan</code>
          <p>进入规划模式</p>
        </div>
        <div class="command-card">
          <code>/resume</code>
          <p>恢复之前的会话</p>
        </div>
        <div class="command-card">
          <code>/mcp</code>
          <p>查看 MCP 连接状态</p>
        </div>
        <div class="command-card">
          <code>/btw</code>
          <p>侧链对话 - 并行提问不中断主任务</p>
        </div>
      </div>
    </div>

    <div class="notice">
      <p>⚠️ 这是一个 UI 演示，不是真实的 Claude Code 连接。</p>
    </div>
  </div>
</Layout>

<style>
  .subtitle {
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-2xl);
  }

  .demo-container {
    max-width: 1000px;
    margin: 0 auto var(--spacing-2xl);
  }

  .terminal {
    background: var(--color-code-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    margin-bottom: var(--spacing-xl);
  }

  .terminal-header {
    background: #2D2D2D;
    padding: var(--spacing-sm) var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .dots {
    display: flex;
    gap: var(--spacing-sm);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #FF5F56; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green { background: #27C93F; }

  .title {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }

  .terminal-content {
    padding: var(--spacing-lg);
    min-height: 300px;
    max-height: 400px;
    overflow-y: auto;
  }

  /* Global styles for dynamically created elements */
  .terminal-content :global(.message) {
    margin-bottom: var(--spacing-md);
    animation: fadeIn 0.3s ease;
    color: #E8E8E8;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .terminal-content :global(.message.user) {
    color: #7AB5FF;
  }

  .terminal-content :global(.message.user .content) {
    color: #7AB5FF;
  }

  .terminal-content :global(.message.assistant) {
    color: #E8E8E8;
  }

  .terminal-content :global(.message.assistant .content) {
    color: #E8E8E8;
  }

  .terminal-content :global(.message.system) {
    color: #FFB86C;
  }

  .terminal-content :global(.message.system .content) {
    color: #FFB86C;
  }

  .terminal-content :global(.message .label) {
    font-weight: 600;
    margin-right: var(--spacing-sm);
    color: #FFFFFF;
  }

  .terminal-content :global(.message .content) {
    color: #E8E8E8;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .input-area {
    display: flex;
    align-items: center;
    padding: var(--spacing-md);
    background: #252525;
    border-top: 1px solid #3D3D3D;
  }

  .prompt {
    color: var(--color-primary);
    margin-right: var(--spacing-sm);
    font-weight: 600;
  }

  .input-area input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--color-surface);
    font-size: 1rem;
    outline: none;
  }

  .input-area button {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: var(--spacing-sm) var(--spacing-lg);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-weight: 500;
  }

  .input-area button:hover {
    background: #c06242;
  }

  .presets-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-3xl);
  }

  .presets-section {
    background: #1E1E1E;
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    border: 1px solid #3D3D3D;
  }

  .presets-section h3 {
    margin-bottom: var(--spacing-md);
    color: #E8E8E8;
    font-size: 1rem;
  }

  .preset-btn {
    display: block;
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-md);
    margin-bottom: var(--spacing-sm);
    background: #2D2D2D;
    border: 1px solid #3D3D3D;
    border-radius: var(--radius-md);
    cursor: pointer;
    text-align: left;
    transition: background var(--transition);
    color: #E8E8E8;
    font-size: 0.875rem;
  }

  .preset-btn:hover {
    background: #3D3D3D;
    color: #FFFFFF;
  }

  .commands-reference {
    max-width: 1000px;
    margin: 0 auto var(--spacing-3xl);
  }

  .commands-reference h2 {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .commands-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--spacing-md);
  }

  .command-card {
    background: var(--color-surface);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    text-align: center;
  }

  .command-card code {
    display: block;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    font-size: 0.9375rem;
  }

  .command-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    margin: 0;
  }

  .notice {
    text-align: center;
    color: var(--color-text);
    padding: var(--spacing-lg);
    background: #FFF8E1;
    border-radius: var(--radius-lg);
    border: 1px solid #FFD54F;
  }

  @media (max-width: 768px) {
    .terminal-content {
      min-height: 200px;
    }

    .presets-wrapper {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const demoResponses = {
    '/help': `可用命令：
/help      - 显示帮助
/init      - 初始化项目
/clear     - 清空对话
/context   - 查看 token 使用
/model     - 切换模型
/plan      - 进入规划模式
/resume    - 恢复会话
/mcp       - MCP 状态`,

    '/init': `正在初始化项目...

✓ 扫描项目结构
✓ 检测到: TypeScript + React
✓ 检测到: Vite 构建工具
✓ 检测到: Vitest 测试框架

已创建 CLAUDE.md 配置文件！`,

    '/clear': `对话上下文已清空。

开始新对话...`,

    '/context': `Session Context Usage:
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Messages: 45,231 / 200,000 tokens
  Remaining: 154,769 tokens (77%)
  Last message: ~1,500 tokens

💡 提示: 剩余 < 20% 时考虑 /clear`,

    '/model': `当前模型: Sonnet 4.5 (默认)

可用模型:
  • Haiku 4.5   - 快速，轻量任务
  • Sonnet 4.5  - 日常开发 (当前)
  • Opus 4.5    - 复杂任务

使用 /model haiku 或 /model opus 切换`,

    '/plan': `📋 进入规划模式...

请描述你想要实现的功能：
1. 功能目标和需求
2. 技术约束和偏好
3. 验收标准

我将为你制定实施计划。`,

    '/resume': `可用会话：
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 [1] 用户认证功能     - 2小时前
 [2] API 设计          - 昨天
 [3] 数据库优化        - 3天前

输入会话编号恢复，或按 0 取消`,

    '/mcp': `MCP Servers Status:
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 ✓ filesystem (本地)
 ✓ git (本地)
 ✓ github (已连接)
 ✗ database (未配置)

可用工具: 12 个`,

        '/btw': `侧链对话模式已开启 💬

你可以在主任务执行时并行提问，答案将显示在浮层中。

使用场景：
• 快速查询：/btw 这个函数是做什么的？
• 概念确认：/btw useEffect 依赖怎么做？
• 相关疑问：/btw 这个错误码是什么意思？

特点：不中断主任务、即时回答、只读模式`,

    'team mode, member 1 修复用户登录的 token 过期问题，member 2 分析 API 响应慢的原因': `🚀 Team Mode 已激活

正在启动两个 subagents 并行工作...

━━━ Member 1: 修复 token 过期 ━━━
任务：修复用户登录的 token 过期问题
状态：正在分析 auth.ts...
• 检测到 token 有效期设置为 30 分钟
• 建议实现 refresh token 机制
• 正在添加自动续期逻辑...

━━━ Member 2: 分析 API 性能 ━━━
任务：分析 API 响应慢的原因
状态：正在 profiling...
• 发现 /api/users 接口响应时间 2.3s
• 数据库查询缺少索引
• 建议���加 users.email 索引

两个任务已完成！准备合并结果...`,

    '审查这个 PR 的安全性，检查是否有 SQL 注入风险': `🔒 安全审查中...

正在检查 PR #123 的安全性...

发现的问题：
❌ 高危: users.ts#45 使用字符串拼接构建 SQL 查询
   const query = \`SELECT * FROM users WHERE id = \${userId}\`

✅ 建议: 使用参数化查询
   const query = 'SELECT * FROM users WHERE id = ?'

其他检查：
✅ 密码使用 bcrypt 加密
✅ API 速率限制已配置
⚠️ 建议: 添加 CSRF token 验证

是否需要我修复这个 SQL 注入问题？`,

    '重构认证模块，使用 JWT 替代 session，需要保持向后兼容': `📋 重构计划确认

目标：认证模块从 session 迁移到 JWT

迁移阶段：
Phase 1: 添加 JWT 支持（保留 session）
  • 安装 jsonwebtoken + @types/jsonwebtoken
  • 实现 JWT 中间件
  • 添加 /auth/token 端点

Phase 2: 双模式运行
  • 同时支持 session 和 JWT
  • 逐步迁移现有客户端
  • 监控错误率

Phase 3: 完全迁移
  • 移除 session 依赖
  • 清理相关代码

向后兼容策略：
• 旧客户端继续使用 session
• 新客户端使用 JWT
• 提供 2 周迁移期

是否开始 Phase 1？`,

    '写单元测试覆盖用户注册流程，包括正常和异常情况': `✅ 测试计划确认

测试场景覆盖：

正常流程：
✓ 用户名和密码有效 → 注册成功
✓ 邮箱发送验证链接
✓ 返回用户信息（不含密码）

边界条件：
✓ 用户名已存在 → 返回 409 错误
✓ 邮箱格式无效 → 返回 400 错误
✓ 密码强度不足 → 返回 400 错误
✓ 缺少必填字段 → 返回 400 错误

异常情况：
✓ 数据库连接失败
✓ 邮件服务不可用
✓ 并发注册相同用户名

使用框架: Vitest + msw (Mock Service Worker)

准备生成测试代码...`
  };

  const terminalContent = document.getElementById('terminal-content');
  const demoInput = document.getElementById('demo-input') as HTMLInputElement;
  const sendBtn = document.getElementById('send-btn');

  function addMessage(type: string, content: string) {
    if (!terminalContent) return;
    const message = document.createElement('div');
    message.className = `message ${type}`;

    const label = document.createElement('span');
    label.className = 'label';
    label.textContent = type === 'user' ? '你' : 'Claude';

    const text = document.createElement('span');
    text.className = 'content';
    text.textContent = content;

    message.appendChild(label);
    message.appendChild(text);
    terminalContent.appendChild(message);
    terminalContent.scrollTop = terminalContent.scrollHeight;
  }

  function handleSend() {
    if (!demoInput) return;
    const input = demoInput.value.trim();
    if (!input) return;

    addMessage('user', input);
    demoInput.value = '';

    // Simulate response
    setTimeout(() => {
      const key = input as keyof typeof demoResponses;
      const response = demoResponses[key] || '我明白了。让我帮你处理这个...';
      addMessage('assistant', response);
    }, 500);
  }

  sendBtn?.addEventListener('click', handleSend);
  demoInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleSend();
  });

  // Preset buttons
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = btn.getAttribute('data-cmd');
      if (demoInput && cmd) {
        demoInput.value = cmd;
        handleSend();
      }
    });
  });

  // Welcome message
  addMessage('system', '欢迎使用 Claude Code！这是一个演示界面，试试输入命令或点击下面的预设按钮。');
</script>
