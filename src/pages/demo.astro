---
import Layout from '../layouts/Layout.astro';
---

<Layout title="交互演示 - Claude Code Tips">
  <div class="container">
    <h1>交互演示</h1>
    <p class="subtitle">体验 Claude Code 的界面和交互</p>

    <div class="demo-container">
      <div class="terminal">
        <div class="terminal-header">
          <div class="dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="title">claude-code</div>
        </div>

        <div class="terminal-content" id="terminal-content">
          <!-- Demo messages will be inserted here -->
        </div>

        <div class="input-area">
          <span class="prompt">></span>
          <input type="text" id="demo-input" placeholder="输入命令或消息..." />
          <button id="send-btn">发送</button>
        </div>
      </div>

      <div class="presets-wrapper">
        <div class="presets-section">
          <h3>📋 基础命令</h3>
          <button class="preset-btn" data-cmd="/help">/help - 显示帮助</button>
          <button class="preset-btn" data-cmd="/init">/init - 初始化项目</button>
          <button class="preset-btn" data-cmd="/clear">/clear - 清空对话</button>
          <button class="preset-btn" data-cmd="/context">/context - Token 使用</button>
        </div>

        <div class="presets-section">
          <h3>🔄 工作流命令</h3>
          <button class="preset-btn" data-cmd="/model">/model - 切换模型</button>
          <button class="preset-btn" data-cmd="/plan">/plan - 进入规划模式</button>
          <button class="preset-btn" data-cmd="/resume">/resume - 恢复会话</button>
          <button class="preset-btn" data-cmd="/mcp">/mcp - MCP 状态</button>
        </div>

        <div class="presets-section">
          <h3>💬 对话示例</h3>
          <button class="preset-btn" data-cmd="帮我创建一个新组件">��建组件示例</button>
          <button class="preset-btn" data-cmd="这个 bug 怎么修复？">调试示例</button>
          <button class="preset-btn" data-cmd="重构这个函数">重构代码</button>
          <button class="preset-btn" data-cmd="写一个测试">编写测试</button>
        </div>
      </div>
    </div>

    <div class="commands-reference">
      <h2>Slash Commands 参考</h2>
      <div class="commands-grid">
        <div class="command-card">
          <code>/init</code>
          <p>初始化项目配置，创建 CLAUDE.md</p>
        </div>
        <div class="command-card">
          <code>/help</code>
          <p>显示所有可用命令</p>
        </div>
        <div class="command-card">
          <code>/clear</code>
          <p>清空对话上下文</p>
        </div>
        <div class="command-card">
          <code>/context</code>
          <p>查看 token 使用情况</p>
        </div>
        <div class="command-card">
          <code>/model</code>
          <p>切换 AI 模型</p>
        </div>
        <div class="command-card">
          <code>/plan</code>
          <p>进入规划模式</p>
        </div>
        <div class="command-card">
          <code>/resume</code>
          <p>恢复之前的会话</p>
        </div>
        <div class="command-card">
          <code>/mcp</code>
          <p>查看 MCP 连接状态</p>
        </div>
      </div>
    </div>

    <div class="notice">
      <p>⚠️ 这是一个 UI 演示，不是真实的 Claude Code 连接。</p>
    </div>
  </div>
</Layout>

<style>
  .subtitle {
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-2xl);
  }

  .demo-container {
    max-width: 1000px;
    margin: 0 auto var(--spacing-2xl);
  }

  .terminal {
    background: var(--color-code-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    margin-bottom: var(--spacing-xl);
  }

  .terminal-header {
    background: #2D2D2D;
    padding: var(--spacing-sm) var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .dots {
    display: flex;
    gap: var(--spacing-sm);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #FF5F56; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green { background: #27C93F; }

  .title {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }

  .terminal-content {
    padding: var(--spacing-lg);
    min-height: 300px;
    max-height: 400px;
    overflow-y: auto;
  }

  /* Global styles for dynamically created elements */
  .terminal-content :global(.message) {
    margin-bottom: var(--spacing-md);
    animation: fadeIn 0.3s ease;
    color: #E8E8E8;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .terminal-content :global(.message.user) {
    color: #7AB5FF;
  }

  .terminal-content :global(.message.user .content) {
    color: #7AB5FF;
  }

  .terminal-content :global(.message.assistant) {
    color: #E8E8E8;
  }

  .terminal-content :global(.message.assistant .content) {
    color: #E8E8E8;
  }

  .terminal-content :global(.message.system) {
    color: #FFB86C;
  }

  .terminal-content :global(.message.system .content) {
    color: #FFB86C;
  }

  .terminal-content :global(.message .label) {
    font-weight: 600;
    margin-right: var(--spacing-sm);
    color: #FFFFFF;
  }

  .terminal-content :global(.message .content) {
    color: #E8E8E8;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .input-area {
    display: flex;
    align-items: center;
    padding: var(--spacing-md);
    background: #252525;
    border-top: 1px solid #3D3D3D;
  }

  .prompt {
    color: var(--color-primary);
    margin-right: var(--spacing-sm);
    font-weight: 600;
  }

  .input-area input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--color-surface);
    font-size: 1rem;
    outline: none;
  }

  .input-area button {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: var(--spacing-sm) var(--spacing-lg);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-weight: 500;
  }

  .input-area button:hover {
    background: #c06242;
  }

  .presets-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-3xl);
  }

  .presets-section {
    background: #1E1E1E;
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    border: 1px solid #3D3D3D;
  }

  .presets-section h3 {
    margin-bottom: var(--spacing-md);
    color: #E8E8E8;
    font-size: 1rem;
  }

  .preset-btn {
    display: block;
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-md);
    margin-bottom: var(--spacing-sm);
    background: #2D2D2D;
    border: 1px solid #3D3D3D;
    border-radius: var(--radius-md);
    cursor: pointer;
    text-align: left;
    transition: background var(--transition);
    color: #E8E8E8;
    font-size: 0.875rem;
  }

  .preset-btn:hover {
    background: #3D3D3D;
    color: #FFFFFF;
  }

  .commands-reference {
    max-width: 1000px;
    margin: 0 auto var(--spacing-3xl);
  }

  .commands-reference h2 {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .commands-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--spacing-md);
  }

  .command-card {
    background: var(--color-surface);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    text-align: center;
  }

  .command-card code {
    display: block;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    font-size: 0.9375rem;
  }

  .command-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    margin: 0;
  }

  .notice {
    text-align: center;
    color: var(--color-text);
    padding: var(--spacing-lg);
    background: #FFF8E1;
    border-radius: var(--radius-lg);
    border: 1px solid #FFD54F;
  }

  @media (max-width: 768px) {
    .terminal-content {
      min-height: 200px;
    }

    .presets-wrapper {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const demoResponses = {
    '/help': `可用命令：
/help      - 显示帮助
/init      - 初始化项目
/clear     - 清空对话
/context   - 查看 token 使用
/model     - 切换模型
/plan      - 进入规划模式
/resume    - 恢复会话
/mcp       - MCP 状态`,

    '/init': `正在初始化项目...

✓ 扫描项目结构
✓ 检测到: TypeScript + React
✓ 检测到: Vite 构建工具
✓ 检测到: Vitest 测试框架

已创建 CLAUDE.md 配置文件！`,

    '/clear': `对话上下文已清空。

开始新对话...`,

    '/context': `Session Context Usage:
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Messages: 45,231 / 200,000 tokens
  Remaining: 154,769 tokens (77%)
  Last message: ~1,500 tokens

💡 提示: 剩余 < 20% 时考虑 /clear`,

    '/model': `当前模型: Sonnet 4.5 (默认)

可用模型:
  • Haiku 4.5   - 快速，轻量任务
  • Sonnet 4.5  - 日常开发 (当前)
  • Opus 4.5    - 复杂任务

使用 /model haiku 或 /model opus 切换`,

    '/plan': `📋 进入规划模式...

请描述你想要实现的功能：
1. 功能目标和需求
2. 技术约束和偏好
3. 验收标准

我将为你制定实施计划。`,

    '/resume': `可用会话：
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 [1] 用户认证功能     - 2小时前
 [2] API 设计          - 昨天
 [3] 数据库优化        - 3天前

输入会话编号恢复，或按 0 取消`,

    '/mcp': `MCP Servers Status:
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 ✓ filesystem (本地)
 ✓ git (本地)
 ✓ github (已连接)
 ✗ database (未配置)

可用工具: 12 个`,

    '帮我创建一个新组件': `好的！我来帮你创建一个新的用户卡片组件。

我会创建：
1. 组件文件 UserCard.astro
2. 相应的样式
3. TypeScript 类型定义

是否继续？`,

    '这个 bug 怎么修复？': `让我帮你分析这个问题。

从错误信息来看，这可能是由以下原因引起的：
1. 未定义的变量访问
2. 异步处理问题
3. 类型不匹配

建议我先查看相关代码，可以吗？`,

    '重构这个函数': `我来分析这个函数。

发现的问题：
• 函数过长 (80+ 行)
• 职责过多
• 缺少类型注解

重构方案：
1. 拆分为 3 个小函数
2. 添加类型注解
3. 添加错误处理

是否开始重构？`,

    '写一个测试': `好的，我来编写测试。

测试覆盖：
• 正常场景
• 边界条件
• 错误处理

使用框架: Vitest + Testing Library

准备开始...`
  };

  const terminalContent = document.getElementById('terminal-content');
  const demoInput = document.getElementById('demo-input') as HTMLInputElement;
  const sendBtn = document.getElementById('send-btn');

  function addMessage(type: string, content: string) {
    if (!terminalContent) return;
    const message = document.createElement('div');
    message.className = `message ${type}`;

    const label = document.createElement('span');
    label.className = 'label';
    label.textContent = type === 'user' ? '你' : 'Claude';

    const text = document.createElement('span');
    text.className = 'content';
    text.textContent = content;

    message.appendChild(label);
    message.appendChild(text);
    terminalContent.appendChild(message);
    terminalContent.scrollTop = terminalContent.scrollHeight;
  }

  function handleSend() {
    if (!demoInput) return;
    const input = demoInput.value.trim();
    if (!input) return;

    addMessage('user', input);
    demoInput.value = '';

    // Simulate response
    setTimeout(() => {
      const key = input as keyof typeof demoResponses;
      const response = demoResponses[key] || '我明白了。让我帮你处理这个...';
      addMessage('assistant', response);
    }, 500);
  }

  sendBtn?.addEventListener('click', handleSend);
  demoInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleSend();
  });

  // Preset buttons
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = btn.getAttribute('data-cmd');
      if (demoInput && cmd) {
        demoInput.value = cmd;
        handleSend();
      }
    });
  });

  // Welcome message
  addMessage('system', '欢迎使用 Claude Code！这是一个演示界面，试试输入命令或点击下面的预设按钮。');
</script>
