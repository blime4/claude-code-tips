---
import Layout from '../layouts/Layout.astro';

const basePath = '/claude-code-tips';
---

<Layout title="快速入门 - Claude Code Tips">
  <div class="page-wrapper">
    <div class="content-wrapper">
      <header class="page-header">
        <div class="header-badge">
          <span class="badge-icon">⚡</span>
          <span class="badge-text">Quick Start</span>
        </div>
        <h1>快速入门</h1>
        <p class="subtitle">5 分钟上手 Claude Code</p>
      </header>

      <section class="step-card" id="install">
        <div class="step-header">
          <span class="step-number">01</span>
          <h2>安装</h2>
        </div>

        <div class="method-group">
          <h3>
            <span class="method-icon">npm</span>
            方法一：npm 安装（推荐）
          </h3>

          <div class="option-tabs">
            <div class="tab active">
              <span class="flag">🇨🇳</span>
              中国大陆
            </div>
            <div class="tab">
              <span class="flag">🌍</span>
              其他地区
            </div>
          </div>

          <div class="option-content">
            <div class="option-pane active">
              <p class="option-desc">使用淘宝镜像加速，安装更快更稳定</p>
              <div class="code-block-wrapper">
                <pre class="code-block"><code># 配置 npm 使用淘宝镜像
npm config set registry https://registry.npmmirror.com

# 安装 Claude Code
npm install -g @anthropic-ai/claude-code</code></pre>
                <button class="copy-btn" title="复制代码">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>

          <details class="collapse">
            <summary class="collapse-header">
              <span class="collapse-icon">▸</span>
              <span>权限问题解决方案</span>
            </summary>
            <div class="collapse-content">
              <p>如果遇到 <code class="inline-code">EACCES</code> 权限错误，可以安装到用户目录：</p>
              <div class="code-block-wrapper">
                <pre class="code-block"><code>mkdir -p ~/.npm-global
npm config set prefix '~/.npm-global'
npm install -g @anthropic-ai/claude-code

# 添加到 PATH（添加到 ~/.bashrc 或 ~/.zshrc）
export PATH=~/.npm-global/bin:$PATH</code></pre>
              </div>
            </div>
          </details>
        </div>

        <div class="method-group">
          <h3>
            <span class="method-icon">📜</span>
            方法二：原生安装脚本
          </h3>
          <div class="code-block-wrapper">
            <pre class="code-block"><code># macOS、Linux、WSL
curl -fsSL https://claude.ai/install.sh | bash

# Windows PowerShell
irm https://claude.ai/install.ps1 | iex</code></pre>
          </div>
        </div>

        <div class="method-group">
          <h3>
            <span class="method-icon">🍺</span>
            方法三：Homebrew（macOS）
          </h3>
          <div class="code-block-wrapper">
            <pre class="code-block"><code>brew install --cask claude-code</code></pre>
          </div>
        </div>
      </section>

      <section class="step-card" id="first-run">
        <div class="step-header">
          <span class="step-number">02</span>
          <h2>首次运行</h2>
        </div>
        <div class="code-block-wrapper">
          <pre class="code-block"><code># 进入你的项目目录
cd my-project

# 启动 Claude Code
claude</code></pre>
        </div>
      </section>

      <section class="step-card" id="init">
        <div class="step-header">
          <span class="step-number">03</span>
          <h2>初始化配置</h2>
        </div>
        <div class="code-block-wrapper">
          <pre class="code-block"><code>/init</code></pre>
        </div>
        <p class="info-text">
          <span class="info-icon">💡</span>
          这将扫描项目并创建 <code class="inline-code">CLAUDE.md</code> 配置文件。
        </p>
      </section>

      <section class="step-card" id="commands">
        <div class="step-header">
          <span class="step-number">04</span>
          <h2>基本命令</h2>
        </div>
        <div class="commands-grid">
          <div class="command-item">
            <code class="command-name">/help</code>
            <span class="command-desc">显示所有命令</span>
          </div>
          <div class="command-item">
            <code class="command-name">/clear</code>
            <span class="command-desc">清空对话</span>
          </div>
          <div class="command-item">
            <code class="command-name">/context</code>
            <span class="command-desc">查看 token 使用</span>
          </div>
          <div class="command-item">
            <code class="command-name">/model</code>
            <span class="command-desc">切换模型</span>
          </div>
        </div>
      </section>

      <section class="step-card" id="start">
        <div class="step-header">
          <span class="step-number">05</span>
          <h2>开始使用</h2>
        </div>
        <div class="features-list">
          <div class="feature-item">
            <span class="feature-icon">💬</span>
            <span>用自然语言描述你想做什么</span>
          </div>
          <div class="feature-item">
            <span class="feature-icon">🖼️</span>
            <span>拖拽截图进行分析</span>
          </div>
          <div class="feature-item">
            <span class="feature-icon">✏️</span>
            <span>让 Claude 阅读、修改、创建文件</span>
          </div>
        </div>
      </section>

      <section class="cta-section">
        <div class="cta-card">
          <h2>准备好开始了吗？</h2>
          <p>探索更多 Claude Code 使用技巧和最佳实践</p>
          <a href={`${basePath}/tips`} class="cta-btn">
            浏览所有技巧
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </section>
    </div>

    <aside class="page-sidebar">
      <div class="sidebar-section">
        <h3>页面导航</h3>
        <nav class="toc">
          <a href="#install" class="toc-link active">安装</a>
          <a href="#first-run" class="toc-link">首次运行</a>
          <a href="#init" class="toc-link">初始化配置</a>
          <a href="#commands" class="toc-link">基本命令</a>
          <a href="#start" class="toc-link">开始使用</a>
        </nav>
      </div>
      <div class="sidebar-section">
        <h3>相关链接</h3>
        <div class="link-list">
          <a href={`${basePath}/demo`} class="sidebar-link">
            <span>交互演示</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
          </a>
          <a href={`${basePath}/best-practices`} class="sidebar-link">
            <span>最佳实践</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
          </a>
        </div>
      </div>
    </aside>
  </div>
</Layout>

<style>
  :root {
    --claude-terracotta: #D97757;
    --claude-terracotta-dark: #C06242;
    --claude-warm-gray: #73675C;
    --claude-cream: #FAF9F7;
    --claude-border: #E8E4E1;
    --claude-text: #2C2C2C;
    --claude-text-secondary: #6B6560;
    --claude-code-bg: #1A1A2E;
    --claude-step-bg: #F5F3F1;
  }

  .page-wrapper {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--spacing-2xl);
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-2xl) var(--spacing-lg);
  }

  .content-wrapper {
    min-width: 0;
  }

  /* Page Header */
  .page-header {
    text-align: center;
    padding: var(--spacing-3xl) 0;
    margin-bottom: var(--spacing-2xl);
    background: linear-gradient(135deg, var(--claude-cream) 0%, #FFF 100%);
    border-radius: var(--radius-lg);
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--claude-terracotta), var(--claude-warm-gray));
  }

  .header-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    background: rgba(217, 119, 87, 0.1);
    border-radius: 100px;
    font-size: 0.875rem;
    color: var(--claude-terracotta);
    font-weight: 500;
    margin-bottom: var(--spacing-lg);
  }

  .badge-icon {
    font-size: 1rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--claude-text);
    margin-bottom: var(--spacing-sm);
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--claude-text-secondary);
  }

  /* Step Cards */
  .step-card {
    background: var(--color-surface);
    border: 1px solid var(--claude-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .step-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--claude-terracotta);
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--claude-border);
  }

  .step-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--claude-terracotta);
    opacity: 0.3;
    font-variant-numeric: tabular-nums;
  }

  .step-header h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--claude-text);
    margin: 0;
  }

  /* Method Groups */
  .method-group {
    margin-bottom: var(--spacing-xl);
  }

  .method-group:last-child {
    margin-bottom: 0;
  }

  .method-group h3 {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 1rem;
    font-weight: 600;
    color: var(--claude-text);
    margin-bottom: var(--spacing-md);
  }

  .method-icon {
    font-size: 1.25rem;
  }

  /* Option Tabs */
  .option-tabs {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
    background: var(--claude-step-bg);
    padding: var(--spacing-xs);
    border-radius: var(--radius-md);
  }

  .tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--claude-text-secondary);
    cursor: pointer;
    transition: all var(--transition);
  }

  .tab.active {
    background: var(--color-surface);
    color: var(--claude-text);
    box-shadow: var(--shadow-sm);
  }

  .flag {
    font-size: 1rem;
  }

  .option-desc {
    color: var(--claude-text-secondary);
    font-size: 0.875rem;
    margin-bottom: var(--spacing-md);
  }

  /* Code Blocks */
  .code-block-wrapper {
    position: relative;
    margin: var(--spacing-md) 0;
  }

  .code-block {
    background: var(--claude-code-bg);
    color: #E8E8E8;
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
  }

  .copy-btn {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: var(--radius-sm);
    color: white;
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .code-block-wrapper:hover .copy-btn {
    opacity: 1;
  }

  .copy-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .inline-code {
    background: var(--claude-step-bg);
    color: var(--claude-terracotta);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  /* Collapse */
  .collapse {
    margin-top: var(--spacing-md);
    border: 1px solid var(--claude-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .collapse-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    background: var(--claude-step-bg);
    cursor: pointer;
    user-select: none;
    font-weight: 500;
  }

  .collapse-icon {
    transition: transform var(--transition);
  }

  .collapse[open] .collapse-icon {
    transform: rotate(90deg);
  }

  .collapse-content {
    padding: var(--spacing-md);
    border-top: 1px solid var(--claude-border);
  }

  /* Commands Grid */
  .commands-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  .command-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    background: var(--claude-step-bg);
    border-radius: var(--radius-md);
    transition: all var(--transition);
  }

  .command-item:hover {
    background: var(--claude-border);
  }

  .command-name {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--claude-terracotta);
    background: var(--color-surface);
    padding: 0.25em 0.5em;
    border-radius: var(--radius-sm);
  }

  .command-desc {
    color: var(--claude-text-secondary);
    font-size: 0.875rem;
  }

  /* Features List */
  .features-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    background: var(--claude-step-bg);
    border-radius: var(--radius-md);
  }

  .feature-icon {
    font-size: 1.5rem;
  }

  .info-text {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    color: var(--claude-text-secondary);
  }

  .info-icon {
    font-size: 1rem;
  }

  /* CTA Section */
  .cta-section {
    margin-top: var(--spacing-2xl);
  }

  .cta-card {
    text-align: center;
    padding: var(--spacing-3xl);
    background: linear-gradient(135deg, var(--claude-terracotta) 0%, var(--claude-terracotta-dark) 100%);
    border-radius: var(--radius-lg);
    color: white;
  }

  .cta-card h2 {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    color: white;
  }

  .cta-card p {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--spacing-xl);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-xl);
    background: white;
    color: var(--claude-terracotta);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    transition: all var(--transition);
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  /* Sidebar */
  .page-sidebar {
    position: sticky;
    top: var(--spacing-2xl);
    height: fit-content;
  }

  .sidebar-section {
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-lg);
    background: var(--color-surface);
    border: 1px solid var(--claude-border);
    border-radius: var(--radius-md);
  }

  .sidebar-section h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--claude-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }

  .toc {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .toc-link {
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-sm);
    color: var(--claude-text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: all var(--transition);
  }

  .toc-link:hover,
  .toc-link.active {
    background: var(--claude-step-bg);
    color: var(--claude-text);
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-sm);
    color: var(--claude-text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: all var(--transition);
  }

  .sidebar-link:hover {
    background: var(--claude-step-bg);
    color: var(--claude-text);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .page-wrapper {
      grid-template-columns: 1fr;
    }

    .page-sidebar {
      display: none;
    }

    .commands-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .page-wrapper {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .page-header {
      padding: var(--spacing-xl) 0;
    }

    .page-header h1 {
      font-size: 1.75rem;
    }

    .option-tabs {
      flex-direction: column;
    }

    .step-header {
      flex-wrap: wrap;
    }

    .cta-card {
      padding: var(--spacing-xl);
    }
  }
</style>
